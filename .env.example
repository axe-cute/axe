# =============================================================================
# axe — Go Web Framework
# Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# Server
SERVER_PORT=8080
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=debug           # debug | info | warn | error

# Database (PostgreSQL)
DATABASE_URL=postgres://axe:axe@localhost:5432/axe_dev?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME_MINUTES=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_RETRIES=3

# Auth
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Asynq (uses Redis)
ASYNQ_CONCURRENCY=10
ASYNQ_QUEUE_DEFAULT=default
ASYNQ_QUEUE_CRITICAL=critical

# WebSocket Hub
HUB_ADAPTER=memory            # memory | redis

# Storage Plugin
STORAGE_BACKEND=local          # local | juicefs
STORAGE_MOUNT_PATH=./uploads   # local dir or JuiceFS mountpoint (e.g. /mnt/jfs/uploads)
STORAGE_MAX_FILE_SIZE=10485760 # 10MB in bytes
STORAGE_URL_PREFIX=/upload

# CORS
CORS_ALLOWED_ORIGINS=*            # comma-separated, e.g. https://app.example.com,http://localhost:3000

# Observability (optional for local dev)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=axe
